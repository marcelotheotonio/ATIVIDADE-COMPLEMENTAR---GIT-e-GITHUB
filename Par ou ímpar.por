programa {
  funcao inicio() {

 //Par ou ímpar

  inteiro numero
  
  escreva("Digite o número que deseja saber se é par ou ímpar: ")
    leia(numero)
  
    se(numero%2==0){
        escreva(" O número ",numero," é par! ")
        escreva("\n")
    }
    senao{
         escreva(" O número ",numero," é ímpar! ") 
         escreva("\n")
             }

  }
}
