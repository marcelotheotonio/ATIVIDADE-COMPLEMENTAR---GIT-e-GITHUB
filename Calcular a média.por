programa {
  funcao inicio() {
    
//Cálculo de média

  real num1 , num2 , num3, media

  escreva("Digite três números para o cálculo da média aritmética! \n")
  leia(num1)"\n"
  leia(num2)"\n"
  leia(num3)"\n"

  media = (num1+num2+num3) / 3 

  escreva("A média aritimética destes três números é: ", media) 
  escreva("\n")

  }
}
