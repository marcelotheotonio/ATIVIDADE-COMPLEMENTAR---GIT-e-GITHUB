programa {
  funcao inicio() {
    
//Fatorial de um número

    inteiro num1 , fatorial=1

    escreva("Informe o número que deseja saber o fatorial dele: ")
    leia(num1)

      para(inteiro i=1;i<=num1;i++){

          fatorial=fatorial*i
            }

      escreva("O fatorial de " , num1 ," é = " , fatorial)


       }

  }

