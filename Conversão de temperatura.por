programa {
  funcao inicio() {
    
//Conversão de temperatura

real celsius , temperatura

escreva("Digite a temperatura que deseja converter de Celsius para Fahrenheit: \n")
leia(celsius)

temperatura = (celsius*1.8) + 32

escreva("A temperatura informada, convertida em Farenheit é: " , temperatura)
escreva("\n")

  }
}
